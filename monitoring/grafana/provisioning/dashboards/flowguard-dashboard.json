{
  "title": "FlowGuard Overview",
  "uid": "flowguard-overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate by Status Class (HTTP, self)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"FlowGuard\"}[1m])) by (status)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Rate Limiter Decisions",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(flowguard_ratelimit_requests_total[1m])) by (algorithm, result)",
          "legendFormat": "{{algorithm}} - {{result}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Rate Limit Rejection %",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "100 * sum(rate(flowguard_ratelimit_requests_total{result=\"rejected\"}[5m])) / sum(rate(flowguard_ratelimit_requests_total[5m]))",
          "legendFormat": "rejected %"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 2 }, "overrides": [] }
    },
    {
      "id": 4,
      "title": "Circuit Breaker Decisions",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(flowguard_circuit_breaker_decisions_total[1m])) by (result)",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Circuit Breaker State (observed)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(flowguard_circuit_breaker_state_total[1m])) by (state)",
          "legendFormat": "{{state}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "IP Blocks / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "rate(flowguard_ip_blocked_total[1m])",
          "legendFormat": "blocked"
        }
      ]
    },
    {
      "id": 7,
      "title": "Webhook Dispatches by Event",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(flowguard_webhook_dispatched_total[1m])) by (event)",
          "legendFormat": "{{event}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "Webhook Delivery Outcomes",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(flowguard_webhook_delivery_total[1m])) by (result)",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "id": 9,
      "title": "Upstream Response Status Classes",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "sum(rate(flowguard_upstream_responses_total[1m])) by (status_class)",
          "legendFormat": "{{status_class}}"
        }
      ]
    },
    {
      "id": 10,
      "title": "JVM Heap Used",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{application=\"FlowGuard\", area=\"heap\"})",
          "legendFormat": "heap used"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] }
    },
    {
      "id": 11,
      "title": "p95 HTTP Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 24 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"FlowGuard\"}[5m])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    }
  ]
}